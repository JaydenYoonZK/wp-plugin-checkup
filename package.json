{
  "name": "wp-plugin-checkup",
  "version": "1.2.15",
  "description": "Check WordPress plugins against WordPress.org for removed, abandoned, and untested ones. Browser-based, no dependencies.",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "node --check docs/checkup.js && node --check docs/app.js",
    "test": "node --test test/checkup.test.mjs",
    "test:coverage": "node --experimental-test-coverage --test test/checkup.test.mjs",
    "serve": "python3 -m http.server 8421 -d docs"
  },
  "engines": { "node": ">=20" },
  "files": [
    "docs/checkup.js",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "author": "Jayden Yoon ZK",
  "repository": { "type": "git", "url": "https://github.com/JaydenYoonZK/wp-plugin-checkup.git" }
}
